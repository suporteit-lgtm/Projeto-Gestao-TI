{
  "name": "inventario-ti-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "vercel-build": "cd ../backend && npm install && npx prisma generate && cd ../frontend && mkdir -p node_modules/@prisma && cp -r ../backend/node_modules/.prisma ./node_modules/ && cp -r ../backend/node_modules/@prisma/client ./node_modules/@prisma/ && tsc && vite build"
  },
  "dependencies": {
    "@tabler/icons-webfont": "^3.44.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
